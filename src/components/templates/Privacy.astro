---
// 隱私權政策模板 — editorial 版型:安靜頁首 + 單欄窄版純文字
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import { getDict, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
---

<Base lang={lang} path="/privacy" title={t.pageMeta.privacy.title} description={t.pageMeta.privacy.description}>
  <PageHeader eyebrow="PRIVACY" title={t.privacy.title} />

  <section class="section privacy-page">
    <div class="container reading-column fade-up">
      <p class="privacy-page__note">{t.privacy.lastUpdated}</p>
      {t.privacy.sections.map((section) => (
        <div class="privacy-page__section">
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .privacy-page__note {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }
  .privacy-page__section {
    margin-top: var(--space-5);
  }
  .privacy-page__section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }
  .privacy-page__section p {
    color: var(--color-ink-soft);
  }
</style>
