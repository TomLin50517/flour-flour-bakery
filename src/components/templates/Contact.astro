---
// 聯絡我們模板 — editorial 版型:安靜頁首 + 左資訊 / 右地圖(click-to-load)+ 下方表單
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import MapEmbed from '../MapEmbed.astro';
import ContactForm from '../ContactForm.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const phoneHref = `tel:${t.contact.phoneValue.replace(/-/g, '')}`;
const emailHref = `mailto:${t.contact.emailValue}`;
---

<Base lang={lang} path="/contact" title={t.pageMeta.contact.title} description={t.pageMeta.contact.description}>
  <PageHeader eyebrow="CONTACT" title={t.contact.bannerTitle} />

  <section class="section container contact-layout">
    <div class="contact-info fade-up">
      <h2 class="contact-heading">{t.contact.infoHeading}</h2>
      <dl>
        <dt>{t.contact.phoneLabel}</dt>
        <dd><a href={phoneHref}>{t.contact.phoneValue}</a></dd>
        <dt>{t.contact.emailLabel}</dt>
        <dd><a href={emailHref}>{t.contact.emailValue}</a></dd>
        <dt>{t.contact.addressLabel}</dt>
        <dd>{t.contact.addressValue}</dd>
        <dt>{t.contact.hoursLabel}</dt>
        <dd>{t.contact.hoursValue}</dd>
        <dt>{t.contact.socialLabel}</dt>
        <dd>Instagram {t.contact.instagram} · LINE {t.contact.line}</dd>
      </dl>
    </div>

    <div class="contact-map fade-up">
      <MapEmbed placeholderText={t.contact.mapPlaceholder} loadCta={t.contact.mapLoadCta} address={t.contact.addressValue} />
    </div>
  </section>

  <section class="section container contact-form-section fade-up">
    <ContactForm form={t.contact.form} privacyHref={`${p}/privacy`} />
  </section>
</Base>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .contact-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }
  .contact-info dt {
    color: var(--color-ink-soft);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: var(--space-3);
  }
  .contact-info dt:first-of-type {
    margin-top: 0;
  }
  .contact-info dd {
    margin: var(--space-1) 0 0;
  }
  .contact-info a {
    color: var(--color-accent-text);
    text-decoration: none;
  }
  .contact-form-section {
    max-width: var(--reading-max-width);
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
