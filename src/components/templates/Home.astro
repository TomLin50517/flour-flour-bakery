---
// 首頁 — 安靜奢華編輯版型:Hero(92vh 單張攝影)→ Manifesto(純文字留白)→ Signature(非對稱)
// → The Place(河岸場域)→ Today's Bake(3 款)→ Gift(深色)→ Visit → Minimal Footer(Base 內建)
import Base from '../../layouts/Base.astro';
import ProductCard from '../ProductCard.astro';
import { getDict, getBusinessInfo, localePrefix, type Lang } from '../../i18n';
import { getProducts } from '../../data/products';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const b = getBusinessInfo(lang);
const p = localePrefix[lang];

const featured = getProducts(lang).slice(0, 3);
---

<Base
  lang={lang}
  path="/"
  title={t.pageMeta.home.title}
  description={t.pageMeta.home.description}
  transparentHeader
>
  <!-- 1. Hero:單張淡水夕陽攝影,克制 overlay,單一文字 CTA -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true"></div>
    <div class="hero__scrim" aria-hidden="true"></div>
    <div class="container hero__content">
      <p class="eyebrow hero__eyebrow">CROISSANTS · DANISH · TAMSUI</p>
      <h1 class="hero__title">A Quiet Taste of Tamsui.</h1>
      <p class="hero__subtitle">{t.home.hero.subtitle}</p>
      <a class="link-arrow hero__cta" href={`${p}/story`}>{t.home.hero.cta} →</a>
    </div>
    <span class="hero__scroll-cue" aria-hidden="true"></span>
  </section>

  <!-- 2. Brand Manifesto:純文字、留白 ≥160px、寬 ≤720px -->
  <section class="manifesto">
    <div class="container manifesto__inner reveal-text">
      <p class="manifesto__heading">{t.home.manifesto.heading}</p>
      {t.home.manifesto.body && <p class="manifesto__body">{t.home.manifesto.body}</p>}
    </div>
  </section>

  <!-- 3. Signature Product:非對稱,圖佔約 65%,無價格 -->
  <section class="section signature">
    <div class="container signature__grid">
      <div class="signature__media reveal-media">
        <img src="/images/signature-danish-youtiao.jpg" alt={t.home.signature.name} class="signature__photo" width="782" height="978" loading="lazy" decoding="async" />
      </div>
      <div class="signature__content reveal-text">
        <p class="eyebrow">FLOURFLOUR SIGNATURE</p>
        <h2>{t.home.signature.name}</h2>
        {t.home.signature.nameEn !== t.home.signature.name && (
          <p class="signature__name-en">{t.home.signature.nameEn}</p>
        )}
        <p class="signature__body">{t.home.signature.body}</p>
        <a class="link-arrow" href={`${p}/products`}>{t.home.signature.cta} →</a>
      </div>
    </div>
  </section>

  <!-- 4. The River / The Place:品牌場域 -->
  <section class="section place">
    <div class="container place__grid">
      <div class="place__content reveal-text">
        <p class="eyebrow">THE PLACE</p>
        <h2>{t.home.place.title}</h2>
        <p class="place__body">{t.home.place.body}</p>
        <a class="link-arrow" href={`${p}/story`}>{t.home.place.cta} →</a>
      </div>
      <div class="place__media reveal-media">
        <img src="/images/place-tamsui-oldhouse.jpg" alt={t.home.place.title} class="place__photo" width="1200" height="800" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- 5. Today's Bake:三款 -->
  <section class="section today" id="today-fresh">
    <div class="container">
      <div class="today__header reveal-text">
        <p class="eyebrow">FEATURED</p>
        <h2>{t.home.todayFresh.heading}</h2>
      </div>
      <div class="today__grid">
        {featured.map((item) => (
          <ProductCard item={item} showPrice={false} alcoholLabel={t.products.alcoholLabel} />
        ))}
      </div>
      <p class="today__cta reveal-text">
        <a class="link-arrow" href={`${p}/products`}>{t.home.todayFresh.cta} →</a>
      </p>
    </div>
  </section>

  <!-- 6. Gift Collection:深色區塊 -->
  <section class="gift">
    <div class="container gift__inner">
      <div class="gift__media reveal-media">
        <img src="/images/gift-saltedyolk-cheese.jpg" alt={t.home.gift.heading} class="gift__photo" width="1114" height="1469" loading="lazy" />
      </div>
      <div class="reveal-text">
        <p class="eyebrow gift__eyebrow">GIFT</p>
        <h2>{t.home.gift.heading}</h2>
        <p class="gift__body">{t.home.gift.body}</p>
        <a class="btn btn--on-dark gift__cta" href={`${p}/products`}>{t.home.gift.cta}</a>
      </div>
    </div>
  </section>

  <!-- 7. Visit FlourFlour -->
  <section class="section visit">
    <div class="container reading-column visit__inner reveal-text">
      <p class="eyebrow">VISIT</p>
      <h2>{t.home.visit.heading}</h2>
      <dl class="visit__details">
        <div>
          <dt>{t.home.visit.hoursLabel}</dt>
          <dd>{b.hours}</dd>
        </div>
        <div>
          <dt>{t.home.visit.addressLabel}</dt>
          <dd>{b.address}</dd>
        </div>
        <div>
          <dt>{t.home.visit.phoneLabel}</dt>
          <dd>{b.phone}</dd>
        </div>
      </dl>
      <a class="link-arrow" href={`${p}/contact`}>{t.home.visit.cta} →</a>
    </div>
  </section>
</Base>

<style>
  /* ---- 1. hero:92vh,單張影像,克制 overlay ---- */
  .hero {
    position: relative;
    min-height: 92vh;
    min-height: 92svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    background: var(--cocoa) url('/images/hero-tamsui-bridge.jpg') center center / cover no-repeat;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(33, 30, 27, 0.08) 0%, rgba(33, 30, 27, 0.38) 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    color: var(--flour-white);
    max-width: 820px;
  }
  .hero__eyebrow {
    color: var(--flour-white);
    opacity: 0.85;
  }
  h1.hero__title {
    font-family: var(--font-heading-en);
    font-style: italic;
    font-weight: var(--font-weight-medium);
    font-size: var(--text-5xl);
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  .hero__subtitle {
    font-family: var(--font-body-locale);
    font-size: var(--text-lg);
    color: var(--flour-white);
    opacity: 0.92;
    max-width: var(--reading-max-width);
  }
  .hero__cta {
    color: var(--flour-white);
    margin-top: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Hero scroll cue:底部細長髮絲線,向下漸隱,暗示下方尚有內容。極克制、無迴圈動畫 */
  /* Scroll cue:一條淡髮絲軌道 + 頂端小圓點沿線緩慢下移,明確傳達「往下捲」。
     軌道本身很淡,靠會動的小圓點讀出「元件」感;圓點帶深色微光,疊在亮水面上也看得見。 */
  .hero__scroll-cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-4);
    z-index: 1;
    width: 1px;
    height: 48px;
    transform: translateX(-50%);
    /* 軌道:更淡,不搶戲 */
    background: linear-gradient(to bottom, rgba(243, 239, 232, 0.35), rgba(243, 239, 232, 0.04));
    pointer-events: none;
  }
  /* 沿軌道下移的小圓點 */
  .hero__scroll-cue::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--flour-white);
    box-shadow: 0 0 6px rgba(33, 30, 27, 0.4); /* 深色微光:亮背景上也看得出來 */
    transform: translate(-50%, 0);
  }
  /* 一次性淡入進場(≤700ms);JS 關閉時直接顯示,不依賴動畫 */
  html.js .hero__scroll-cue {
    animation: hero-cue-in 600ms var(--ease-editorial) 450ms both;
  }
  /* 圓點緩慢沿線下移並淡出,循環(克制、緩慢,符合安靜奢華調性) */
  html.js .hero__scroll-cue::before {
    animation: hero-cue-travel 2.6s var(--ease-editorial) 1100ms infinite;
  }
  @keyframes hero-cue-in {
    from {
      opacity: 0;
      transform: translate(-50%, -8px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }
  @keyframes hero-cue-travel {
    0% { transform: translate(-50%, 0); opacity: 0; }
    18% { opacity: 1; }
    72% { opacity: 1; }
    100% { transform: translate(-50%, 42px); opacity: 0; }
  }
  /* 減少動態偏好:不移動、不循環,圓點靜置於軌道頂端,仍讀得出是捲動提示元件 */
  @media (prefers-reduced-motion: reduce) {
    html.js .hero__scroll-cue {
      animation: none;
    }
    html.js .hero__scroll-cue::before {
      animation: none;
    }
  }

  /* ---- 2. manifesto ---- */
  .manifesto {
    background: var(--flour-white);
    padding-block: var(--space-9);
  }
  .manifesto__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }
  .manifesto__heading {
    font-family: var(--font-heading-locale);
    font-style: var(--display-italic);
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.5;
    color: var(--color-ink);
    text-wrap: balance; /* 主張句均衡斷行,避免落單字 */
  }
  .manifesto__body {
    font-family: var(--font-body-locale);
    font-size: var(--text-lg);
    line-height: var(--body-line-height);
    color: var(--color-ink-soft);
    margin-top: var(--space-4);
    max-width: var(--reading-max-width);
    margin-inline: auto;
  }

  /* ---- 3. signature:非對稱 65/35 ---- */
  .signature__grid {
    display: grid;
    grid-template-columns: 65fr 35fr;
    gap: var(--space-7);
    align-items: center;
  }
  .signature__photo {
    width: 100%;
    height: auto; /* 讓 aspect-ratio 主導高度,避免 <img height> 屬性蓋掉 4/5 比例 */
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .signature__content h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .signature__name-en {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-top: var(--space-1);
  }
  .signature__body {
    color: var(--color-ink-soft);
    margin-top: var(--space-3);
    max-width: 52ch;
  }
  .signature__content .link-arrow {
    margin-top: var(--space-4);
  }

  /* ---- 4. the place ---- */
  .place {
    background: var(--color-surface);
  }
  .place__grid {
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: var(--space-7);
    align-items: center;
  }
  .place__content h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .place__body {
    color: var(--color-ink-soft);
    margin-top: var(--space-3);
    max-width: 42ch; /* teaser 感:短行、留白多,不像整段 summary */
  }
  .place__content .link-arrow {
    margin-top: var(--space-4);
  }
  .place__photo {
    width: 100%;
    height: auto; /* 讓 aspect-ratio 主導高度,否則 <img height> 屬性會蓋掉比例 */
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  /* ---- 5. today's bake ---- */
  .today__header {
    text-align: center;
  }
  .today__header h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .today__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-7);
  }
  .today__cta {
    text-align: center;
    margin-top: var(--space-6);
  }

  /* ---- 6. gift:深色 ---- */
  .gift {
    background: var(--deep-ink);
    color: var(--flour-white);
    padding-block: var(--space-8);
  }
  .gift__inner {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }
  .gift__media {
    width: 100%;
    max-width: 360px; /* 禮盒影像收斂為珠寶級尺度,四周留更多深色留白,更高級而非更大 */
    margin-inline: auto;
  }
  .gift__photo {
    width: 100%;
    height: auto;
  }
  .gift__eyebrow {
    color: var(--sunset-copper);
  }
  .gift__inner h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .gift__body {
    color: rgba(243, 239, 232, 0.82);
    margin-top: var(--space-3);
  }
  .gift__cta {
    margin-top: var(--space-2); /* 已是按鈕(自帶內距),與內文的間距略收 */
  }

  /* ---- 7. visit ---- */
  .visit__inner {
    text-align: center;
  }
  .visit__inner h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .visit__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-block: var(--space-6);
  }
  .visit__details dt {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .visit__details dd {
    margin: var(--space-1) 0 0;
    font-family: var(--font-heading-locale);
    font-size: var(--text-xl);
  }

  @media (max-width: 900px) {
    .signature__grid,
    .place__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .place__media {
      order: -1;
    }
    .today__grid {
      grid-template-columns: 1fr;
    }
    .manifesto {
      padding-block: var(--space-8);
    }
  }
  @media (min-width: 900px) and (max-width: 1120px) {
    .today__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
    }
  }
</style>
