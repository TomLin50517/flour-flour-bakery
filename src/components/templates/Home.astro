---
// 首頁模板 — editorial 版型(9 區塊):透明 header / 全螢幕 hero / 品牌宣言 / 招牌單品 / 今日出爐(3款)
// / 老屋河岸故事 / 禮盒 / 來店資訊 / 極簡 footer(Base 內建)
import Base from '../../layouts/Base.astro';
import ProductCard from '../ProductCard.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const featured = t.products.items.filter((item) => !item.soldOut).slice(0, 3);
---

<Base
  lang={lang}
  path="/"
  title={t.pageMeta.home.title}
  description={t.pageMeta.home.description}
  transparentHeader
>
  <!-- 1+2. 全螢幕 hero(透明 header 疊於其上) -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true"></div>
    <div class="hero__scrim" aria-hidden="true"></div>
    <div class="container hero__content">
      <p class="eyebrow hero__eyebrow">{t.home.hero.eyebrow}</p>
      <h1 class="hero__title">{t.home.hero.title}</h1>
      <p class="hero__subtitle">{t.home.hero.subtitle}</p>
      <div class="hero__actions">
        <a class="btn btn--on-dark" href={`${p}/story`}>{t.home.hero.cta}</a>
        <a class="link-arrow" href="#today-fresh">{t.home.hero.cta2}</a>
      </div>
    </div>
  </section>

  <!-- 3. 品牌宣言 -->
  <section class="section manifesto">
    <div class="container reading-column manifesto__inner fade-up">
      <p class="eyebrow">{t.home.manifesto.eyebrow}</p>
      <p class="manifesto__text">{t.home.manifesto.text}</p>
    </div>
  </section>

  <!-- 4. 招牌單品 -->
  <section class="section signature">
    <div class="container signature__grid">
      <div class="signature__image reveal-scale" aria-hidden="true">
        <span>4:5</span>
      </div>
      <div class="signature__content fade-up">
        <p class="eyebrow">{t.home.signature.eyebrow}</p>
        <h2>{t.home.signature.name}</h2>
        <p class="signature__desc">{t.home.signature.description}</p>
        <p class="signature__price">{t.home.signature.price}</p>
        <a class="link-arrow" href={`${p}/products`}>{t.home.signature.cta}</a>
      </div>
    </div>
  </section>

  <!-- 5. 今日出爐(僅 3 款) -->
  <section class="section today" id="today-fresh">
    <div class="container">
      <div class="today__header fade-up">
        <p class="eyebrow">{t.home.todayFresh.eyebrow}</p>
        <h2>{t.home.todayFresh.heading}</h2>
      </div>
      <div class="today__grid">
        {featured.map((item) => (
          <ProductCard item={item} limitedBadgeTemplate={t.products.limitedBadge} soldOutBadge={t.products.soldOutBadge} />
        ))}
      </div>
      <p class="today__cta fade-up">
        <a class="link-arrow" href={`${p}/products`}>{t.home.todayFresh.cta}</a>
      </p>
    </div>
  </section>

  <!-- 6. 老屋與河岸的故事 -->
  <section class="section story">
    <div class="container story__grid">
      <div class="story__image reveal-scale" aria-hidden="true">
        <span>3:4</span>
      </div>
      <div class="story__content fade-up">
        <p class="eyebrow">{t.home.story.eyebrow}</p>
        <h2>{t.home.story.heading}</h2>
        <p>{t.home.story.body}</p>
        <a class="link-arrow" href={`${p}/story`}>{t.home.story.cta}</a>
      </div>
    </div>
  </section>

  <!-- 7. 禮盒 -->
  <section class="section gift">
    <div class="container gift__grid">
      <div class="gift__content fade-up">
        <p class="eyebrow">{t.home.gift.eyebrow}</p>
        <h2>{t.home.gift.heading}</h2>
        <p>{t.home.gift.body}</p>
        <a class="btn" href={`${p}/products`}>{t.home.gift.cta}</a>
      </div>
      <div class="gift__image reveal-scale" aria-hidden="true">
        <span>4:5</span>
      </div>
    </div>
  </section>

  <!-- 8. 來店資訊 -->
  <section class="section visit">
    <div class="container reading-column visit__inner fade-up">
      <p class="eyebrow">{t.home.visit.eyebrow}</p>
      <h2>{t.home.visit.heading}</h2>
      <dl class="visit__details">
        <div>
          <dt>{t.home.visit.hoursLabel}</dt>
          <dd>{t.home.visit.hoursValue}</dd>
        </div>
        <div>
          <dt>{t.home.visit.addressLabel}</dt>
          <dd>{t.home.visit.addressValue}</dd>
        </div>
        <div>
          <dt>{t.home.visit.phoneLabel}</dt>
          <dd>{t.home.visit.phoneValue}</dd>
        </div>
      </dl>
      <a class="btn btn--primary" href={`${p}/contact`}>{t.home.visit.cta}</a>
    </div>
  </section>

  <!-- 9. footer 由 Base.astro 內建的極簡編輯感 Footer 元件提供 -->
</Base>

<style>
  /* ---- 1+2. hero ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 28% 78%, rgba(169, 111, 78, 0.35), transparent 60%),
      linear-gradient(180deg, var(--cocoa-brown) 0%, var(--ink-brown) 75%);
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(41, 36, 31, 0.1) 0%, rgba(41, 36, 31, 0.55) 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    color: var(--flour-white);
    max-width: 780px;
  }
  .hero__eyebrow {
    color: var(--honey-amber);
  }
  h1.hero__title {
    font-family: var(--font-heading-en);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-5xl);
    letter-spacing: 0;
    line-height: 1.15;
  }
  .hero__subtitle {
    font-family: var(--font-body-locale);
    font-size: var(--text-lg);
    color: var(--warm-ivory);
    max-width: var(--reading-max-width);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__content .link-arrow {
    color: var(--flour-white);
  }

  /* ---- 3. manifesto ---- */
  .manifesto__inner {
    text-align: center;
  }
  .manifesto__text {
    font-family: var(--font-heading-locale);
    font-style: var(--display-italic);
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.6;
    color: var(--color-ink);
    margin-top: var(--space-3);
  }

  /* ---- shared editorial split layout (signature / story / gift) ---- */
  .signature__grid,
  .story__grid,
  .gift__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .signature__image,
  .story__image,
  .gift__image {
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }
  .story__image {
    aspect-ratio: 3 / 4;
  }
  .signature__content h2,
  .story__content h2,
  .gift__content h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .signature__desc,
  .story__content p,
  .gift__content p {
    color: var(--color-ink-soft);
    margin-top: var(--space-3);
    max-width: var(--reading-max-width);
  }
  .signature__price {
    font-family: var(--font-heading-en);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-top: var(--space-3);
  }
  .signature__content .link-arrow,
  .story__content .link-arrow {
    display: inline-block;
    margin-top: var(--space-4);
  }
  .gift__content .btn {
    margin-top: var(--space-4);
  }

  .gift {
    background: var(--color-surface);
  }

  /* ---- 5. today's bake ---- */
  .today__header {
    text-align: center;
  }
  .today__header h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .today__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-7);
  }
  .today__cta {
    text-align: center;
    margin-top: var(--space-6);
  }

  /* ---- 8. visit ---- */
  .visit__inner {
    text-align: center;
  }
  .visit__inner h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .visit__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-block: var(--space-6);
  }
  .visit__details dt {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .visit__details dd {
    margin: var(--space-1) 0 0;
    font-family: var(--font-heading-locale);
    font-size: var(--text-xl);
  }

  @media (max-width: 900px) {
    .signature__grid,
    .story__grid,
    .gift__grid {
      grid-template-columns: 1fr;
    }
    .gift__image {
      order: -1;
    }
    .today__grid {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 900px) and (max-width: 1120px) {
    .today__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
