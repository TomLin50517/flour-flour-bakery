---
// 品牌故事 — 五章編輯版型(01 The River / 02 The Flour / 03 The Flower / 04 The Fold / 05 The Light):
// 每章一張大圖 + 英文小標 + 在地語標題 + 40–80 字內文,無卡片框;結尾深色金句 + CTA
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import ImagePlaceholder from '../ImagePlaceholder.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

// 各章影像:01 河/02 粉/03 花/04 摺為橫幅實景(3:2),05 光為直幅夕陽(4:5);
// aspect 依實際照片方向設定,避免把橫幅硬裁成直幅。src 未提供時仍回退佔位系統。
const chapterImage = [
  { label: 'Place Photography', ratio: '3:2', aspect: '3 / 2', src: '/images/story-river.jpg' },
  { label: 'Craft Photography', ratio: '3:2', aspect: '3 / 2', src: '/images/story-flour.jpg' },
  { label: 'Craft Photography', ratio: '3:2', aspect: '3 / 2', src: '/images/story-flower.jpg' },
  { label: 'Craft Photography', ratio: '3:2', aspect: '3 / 2', src: '/images/story-fold.jpg' },
  { label: 'Place Photography', ratio: '4:5', aspect: '4 / 5', src: '/images/story-light.jpg' },
] as const;
---

<Base lang={lang} path="/story" title={t.pageMeta.story.title} description={t.pageMeta.story.description}>
  <PageHeader eyebrow="OUR STORY" title={t.story.pageTitle} />

  {t.story.chapters.map((ch, i) => (
    <section class="chapter">
      <div class:list={['container', 'chapter__grid', { 'chapter__grid--flip': i % 2 === 1 }]}>
        <div class="chapter__media reveal-media">
          {chapterImage[i].src ? (
            <img
              src={chapterImage[i].src}
              alt={ch.title}
              class="chapter__photo"
              style={`aspect-ratio: ${chapterImage[i].aspect};`}
              loading="lazy"
            />
          ) : (
            <ImagePlaceholder
              label={chapterImage[i].label}
              ratio={chapterImage[i].ratio}
              aspect={chapterImage[i].aspect}
            />
          )}
        </div>
        <div class="chapter__text reveal-text">
          <p class="chapter__no">{ch.no}</p>
          <p class="eyebrow">{ch.labelEn.toUpperCase()}</p>
          <h2>{ch.title}</h2>
          <p class="chapter__body">{ch.body}</p>
        </div>
      </div>
    </section>
  ))}

  <section class="story-quote">
    <div class="container reveal-text">
      <img src="/images/logo-flower-ink.png" alt="" class="story-quote__logo" />
      <p>{t.story.quote}</p>
    </div>
  </section>

  <section class="section container story-cta reveal-text">
    <a class="link-arrow" href={`${p}/products`}>{t.story.cta} →</a>
  </section>
</Base>

<style>
  .chapter {
    padding-block: var(--space-7);
  }
  .chapter__grid {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: var(--space-7);
    align-items: center;
  }
  .chapter__grid--flip .chapter__media {
    order: 2;
  }
  .chapter__no {
    font-family: var(--font-heading-en);
    font-size: var(--text-2xl);
    color: var(--color-muted);
  }
  .chapter__text .eyebrow {
    margin-top: var(--space-2);
  }
  .chapter__text h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }
  .chapter__body {
    color: var(--color-ink-soft);
    margin-top: var(--space-3);
    max-width: 46ch;
  }
  .chapter__photo {
    width: 100%;
    object-fit: cover;
  }

  .story-quote {
    background: var(--deep-ink);
    color: var(--flour-white);
    text-align: center;
    padding-block: var(--space-8);
    margin-top: var(--space-7);
  }
  .story-quote__logo {
    height: 40px;
    width: auto;
    margin-inline: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }
  .story-quote p {
    font-family: var(--font-heading-locale);
    font-style: var(--display-italic);
    font-size: var(--text-2xl);
    line-height: 1.6;
    max-width: var(--reading-max-width);
    margin-inline: auto;
    margin-top: var(--space-3);
  }
  .story-cta {
    text-align: center;
  }

  @media (max-width: 900px) {
    .chapter {
      padding-block: var(--space-5);
    }
    .chapter__grid,
    .chapter__grid--flip {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .chapter__grid--flip .chapter__media {
      order: 0;
    }
  }
</style>
