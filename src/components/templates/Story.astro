---
// 品牌故事模板 — editorial 版型:安靜頁首 + 三段式敘事(左右交錯)+ 理念金句(深色滿版)+ CTA
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];
---

<Base lang={lang} path="/story" title={t.pageMeta.story.title} description={t.pageMeta.story.description}>
  <PageHeader eyebrow="OUR STORY" title={t.story.pageTitle} />

  {t.story.sections.map((section, i) => (
    <section class="section container">
      <div class:list={['story-section', { 'story-section--reverse': i % 2 === 1 }]}>
        <div class="story-section__image reveal-scale" aria-hidden="true">3:4</div>
        <div class="story-section__content fade-up">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </div>
      </div>
    </section>
  ))}

  <section class="story-quote">
    <div class="container fade-up">
      <img src="/images/logo-flower.png" alt="flour flour BAKERY" class="story-quote__logo" />
      <p>{t.story.quote}</p>
    </div>
  </section>

  <section class="section container story-cta fade-up">
    <a class="btn btn--primary" href={`${p}/products`}>{t.story.cta}</a>
  </section>
</Base>

<style>
  .story-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .story-section--reverse {
    direction: rtl;
  }
  .story-section--reverse > * {
    direction: ltr;
  }
  .story-section__image {
    aspect-ratio: 3 / 4;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }
  .story-section__content h2 {
    font-size: var(--text-2xl);
  }
  .story-section__content p {
    margin-top: var(--space-3);
    color: var(--color-ink-soft);
    max-width: var(--reading-max-width);
  }
  .story-quote {
    background: var(--color-ink);
    color: var(--warm-ivory);
    text-align: center;
    padding-block: var(--space-8);
  }
  .story-quote__logo {
    height: 40px;
    width: auto;
    margin-inline: auto;
  }
  .story-quote p {
    font-family: var(--font-heading-locale);
    font-style: var(--display-italic);
    font-size: var(--text-2xl);
    line-height: 1.6;
    max-width: var(--reading-max-width);
    margin-inline: auto;
    margin-top: var(--space-3);
  }
  .story-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .story-section,
    .story-section--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }
  }
</style>
