---
// 客服中心模板 — editorial 版型:安靜頁首 + FAQ 手風琴(訂購/商品)+ 訂購須知(細線分隔,無卡片)+ 側欄聯絡引導
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import FAQAccordion from '../FAQAccordion.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const phoneHref = `tel:${t.contact.phoneValue.replace(/-/g, '')}`;
const lineHref = `https://line.me/R/ti/p/${encodeURIComponent(t.contact.line)}`;
---

<Base lang={lang} path="/service" title={t.pageMeta.service.title} description={t.pageMeta.service.description}>
  <PageHeader eyebrow="SERVICE" title={t.service.bannerTitle} />

  <section class="section container service-layout">
    <div class="service-layout__main">
      <div class="fade-up">
        <h2 class="service-heading">{t.service.faq.orderingHeading}</h2>
        <FAQAccordion items={t.service.faq.orderingItems} groupId="ordering" />
      </div>
      <div class="fade-up service-layout__gap">
        <h2 class="service-heading">{t.service.faq.productHeading}</h2>
        <FAQAccordion items={t.service.faq.productItems} groupId="product" />
      </div>

      <div class="order-info fade-up">
        <h2 class="service-heading">{t.service.orderInfo.heading}</h2>
        <dl>
          <dt>{t.service.orderInfo.pickupLabel}</dt>
          <dd>{t.service.orderInfo.pickupValue}</dd>
          <dt>{t.service.orderInfo.paymentLabel}</dt>
          <dd>{t.service.orderInfo.paymentValue}</dd>
          <dt>{t.service.orderInfo.cancellationLabel}</dt>
          <dd>{t.service.orderInfo.cancellationValue}</dd>
        </dl>
      </div>
    </div>

    <aside class="service-sidebar fade-up">
      <h3>{t.service.sidebar.heading}</h3>
      <a class="btn" href={phoneHref}>{t.service.sidebar.callCta}</a>
      <a class="btn" href={lineHref} target="_blank" rel="noopener">{t.service.sidebar.lineCta}</a>
      <a class="link-arrow" href={`${p}/contact`}>{t.service.sidebar.contactCta}</a>
    </aside>
  </section>
</Base>

<style>
  .service-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .service-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }
  .service-layout__gap {
    margin-top: var(--space-6);
  }
  .order-info {
    margin-top: var(--space-6);
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-5);
  }
  .order-info dt {
    color: var(--color-ink-soft);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: var(--space-3);
  }
  .order-info dt:first-of-type {
    margin-top: 0;
  }
  .order-info dd {
    margin: var(--space-1) 0 0;
    max-width: var(--reading-max-width);
  }
  .service-sidebar {
    position: sticky;
    top: 96px;
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .service-sidebar h3 {
    font-size: var(--text-xl);
  }

  @media (max-width: 768px) {
    .service-layout {
      grid-template-columns: 1fr;
    }
    .service-sidebar {
      position: static;
    }
  }
</style>
