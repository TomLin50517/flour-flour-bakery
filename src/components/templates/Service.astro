---
// 客服中心模板(spec §5.4):FAQ 手風琴(訂購/商品)+ 訂購須知卡 + 側欄聯絡引導
import Base from '../../layouts/Base.astro';
import FAQAccordion from '../FAQAccordion.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const phoneHref = `tel:${t.contact.phoneValue.replace(/-/g, '')}`;
const lineHref = `https://line.me/R/ti/p/${encodeURIComponent(t.contact.line)}`;
---

<Base lang={lang} path="/service" title={t.pageMeta.service.title} description={t.pageMeta.service.description}>
  <section class="service-banner">
    <div class="container fade-up">
      <h1>{t.service.bannerTitle}</h1>
    </div>
  </section>

  <section class="section container service-layout">
    <div class="service-layout__main">
      <div class="fade-up">
        <h2>{t.service.faq.orderingHeading}</h2>
        <FAQAccordion items={t.service.faq.orderingItems} groupId="ordering" />
      </div>
      <div class="fade-up service-layout__gap">
        <h2>{t.service.faq.productHeading}</h2>
        <FAQAccordion items={t.service.faq.productItems} groupId="product" />
      </div>

      <div class="order-info fade-up">
        <h2>{t.service.orderInfo.heading}</h2>
        <dl>
          <dt>{t.service.orderInfo.pickupLabel}</dt>
          <dd>{t.service.orderInfo.pickupValue}</dd>
          <dt>{t.service.orderInfo.paymentLabel}</dt>
          <dd>{t.service.orderInfo.paymentValue}</dd>
          <dt>{t.service.orderInfo.cancellationLabel}</dt>
          <dd>{t.service.orderInfo.cancellationValue}</dd>
        </dl>
      </div>
    </div>

    <aside class="service-sidebar fade-up">
      <h3>{t.service.sidebar.heading}</h3>
      <a class="btn" href={phoneHref}>{t.service.sidebar.callCta}</a>
      <a class="btn" href={lineHref} target="_blank" rel="noopener">{t.service.sidebar.lineCta}</a>
      <a class="service-sidebar__link" href={`${p}/contact`}>{t.service.sidebar.contactCta}</a>
    </aside>
  </section>
</Base>

<style>
  .service-banner {
    height: 32vh;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-line);
  }
  .service-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .service-layout__gap {
    margin-top: 48px;
  }
  .order-info {
    margin-top: 48px;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: 32px;
  }
  .order-info dt {
    color: var(--color-ink-soft);
    font-size: 14px;
    margin-top: 16px;
  }
  .order-info dt:first-child {
    margin-top: 0;
  }
  .order-info dd {
    margin: 4px 0 0;
  }
  .service-sidebar {
    position: sticky;
    top: 96px;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
  .service-sidebar__link {
    color: var(--color-rosegold);
    text-decoration: none;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .service-layout {
      grid-template-columns: 1fr;
    }
    .service-sidebar {
      position: static;
    }
  }
</style>
