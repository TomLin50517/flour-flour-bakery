---
// 產品介紹模板(spec §5.3):分類 tab(錨點切換)+ 產品卡格線 + 頁尾備註
import Base from '../../layouts/Base.astro';
import ProductCard from '../ProductCard.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const categoryOrder = ['classic', 'seasonal', 'pastry'] as const;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: t.products.items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: item.name,
      description: item.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'TWD',
        price: item.price,
        availability: item.soldOut ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
      },
    },
  })),
};
---

<Base lang={lang} path="/products" title={t.pageMeta.products.title} description={t.pageMeta.products.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="products-banner">
    <div class="container fade-up">
      <h1>{t.products.bannerTitle}</h1>
    </div>
  </section>

  <nav class="category-tabs" aria-label="product categories">
    <div class="container category-tabs__inner">
      {categoryOrder.map((cat) => (
        <a href={`#${cat}`}>{t.products.categories[cat]}</a>
      ))}
    </div>
  </nav>

  {categoryOrder.map((cat) => (
    <section class="section container" id={cat}>
      <h2 class="section__heading fade-up">{t.products.categories[cat]}</h2>
      <div class="product-grid">
        {t.products.items
          .filter((item) => item.category === cat)
          .map((item) => (
            <ProductCard item={item} limitedBadgeTemplate={t.products.limitedBadge} soldOutBadge={t.products.soldOutBadge} />
          ))}
      </div>
    </section>
  ))}

  <section class="container products-footnote fade-up">
    <p>{t.products.footnote}</p>
    <a class="btn" href={`tel:${t.contact.phoneValue.replace(/-/g, '')}`}>{t.products.footnoteCta}</a>
  </section>
</Base>

<style>
  .products-banner {
    height: 32vh;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-line);
  }
  .category-tabs {
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-line);
    z-index: 10;
  }
  .category-tabs__inner {
    display: flex;
    justify-content: center;
    gap: 32px;
    padding-block: 16px;
  }
  .category-tabs__inner a {
    text-decoration: none;
    color: var(--color-ink);
    font-family: var(--font-body-en);
  }
  .section__heading {
    text-align: center;
    margin-bottom: 48px;
    scroll-margin-top: 80px;
  }
  #classic,
  #seasonal,
  #pastry {
    scroll-margin-top: 64px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .products-footnote {
    text-align: center;
    padding-block: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    color: var(--color-ink-soft);
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
    .category-tabs__inner {
      gap: 16px;
      overflow-x: auto;
    }
  }
  @media (min-width: 480px) and (max-width: 1120px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
