---
// 產品介紹模板 — editorial 版型:安靜頁首 + 分類 tab(錨點切換)+ 產品格線 + 頁尾備註
import Base from '../../layouts/Base.astro';
import PageHeader from '../PageHeader.astro';
import ProductCard from '../ProductCard.astro';
import { getDict, localePrefix, type Lang } from '../../i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang);
const p = localePrefix[lang];

const categoryOrder = ['classic', 'seasonal', 'pastry'] as const;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: t.products.items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: item.name,
      description: item.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'TWD',
        price: item.price,
        availability: item.soldOut ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
      },
    },
  })),
};
---

<Base lang={lang} path="/products" title={t.pageMeta.products.title} description={t.pageMeta.products.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <PageHeader eyebrow="PRODUCTS" title={t.products.bannerTitle} />

  <nav class="category-tabs" aria-label="product categories">
    <div class="container category-tabs__inner">
      {categoryOrder.map((cat) => (
        <a href={`#${cat}`}>{t.products.categories[cat]}</a>
      ))}
    </div>
  </nav>

  {categoryOrder.map((cat) => (
    <section class="section container" id={cat}>
      <h2 class="category-heading fade-up">{t.products.categories[cat]}</h2>
      <div class="product-grid">
        {t.products.items
          .filter((item) => item.category === cat)
          .map((item) => (
            <ProductCard item={item} limitedBadgeTemplate={t.products.limitedBadge} soldOutBadge={t.products.soldOutBadge} />
          ))}
      </div>
    </section>
  ))}

  <section class="container products-footnote fade-up">
    <p>{t.products.footnote}</p>
    <a class="btn" href={`tel:${t.contact.phoneValue.replace(/-/g, '')}`}>{t.products.footnoteCta}</a>
  </section>
</Base>

<style>
  .category-tabs {
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-line);
    z-index: 10;
  }
  .category-tabs__inner {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    padding-block: var(--space-2);
  }
  .category-tabs__inner a {
    text-decoration: none;
    color: var(--color-ink);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
  }
  .category-heading {
    text-align: center;
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }
  #classic,
  #seasonal,
  #pastry {
    scroll-margin-top: 64px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .products-footnote {
    text-align: center;
    padding-block: var(--space-7);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-ink-soft);
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
    .category-tabs__inner {
      gap: var(--space-2);
      overflow-x: auto;
    }
  }
  @media (min-width: 480px) and (max-width: 1120px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
