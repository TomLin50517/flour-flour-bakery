---
// BrandFlower.astro — 品牌花線稿佔位(spec §3.5):暫無正式 Logo 檔案前的簡化花朵 SVG
export interface Props {
  color?: string;
  size?: number;
}

const { color = 'var(--color-rosegold)', size = 48 } = Astro.props;
---

<svg
  class="brand-flower"
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke={color}
  stroke-width="1.5"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="24" cy="24" r="4" />
  <path d="M24 20c0-6 -4-9 -4-14 0 5 -4 8 -4 14" />
  <path d="M28 22c5-3 7-8 12-9 -4 3 -4 8 -8 11" />
  <path d="M28 26c5 3 7 8 12 9 -4-3 -4-8 -8-11" />
  <path d="M24 28c0 6 -4 9 -4 14 0-5 -4-8 -4-14" />
  <path d="M20 22c-5-3 -7-8 -12-9 4 3 4 8 8 11" />
  <path d="M20 26c-5 3 -7 8 -12 9 4-3 4-8 8-11" />
</svg>

<style>
  .brand-flower {
    transition: transform 300ms ease;
  }
  .brand-flower:hover {
    transform: rotate(5deg);
  }
</style>
