---
// ProductCard.astro — editorial 版型:圖 4:5(subtle scale hover)→ 品名(serif)→ 描述 → 價格 / 限量或完售標示(純文字,無 badge 底色)
export interface Props {
  item: {
    id: string;
    name: string;
    description: string;
    price: number;
    dailyLimit: number | null;
    soldOut: boolean;
  };
  limitedBadgeTemplate: string;
  soldOutBadge: string;
}

const { item, limitedBadgeTemplate, soldOutBadge } = Astro.props;
const limitedText = item.dailyLimit ? limitedBadgeTemplate.replace('{n}', String(item.dailyLimit)) : null;
---

<article class:list={['product-card', 'fade-up', { 'product-card--sold-out': item.soldOut }]} data-product-id={item.id}>
  <div class="product-card__frame">
    <div class="product-card__image" aria-hidden="true">4:5</div>
  </div>
  <div class="product-card__body">
    <h3>{item.name}</h3>
    <p class="product-card__desc">{item.description}</p>
    <p class="product-card__meta">
      <span class="product-card__price">NT$ {item.price}</span>
      {limitedText && !item.soldOut && <span class="product-card__note">{limitedText}</span>}
      {item.soldOut && <span class="product-card__note product-card__note--soldout">{soldOutBadge}</span>}
    </p>
  </div>
</article>

<style>
  .product-card__frame {
    overflow: hidden;
  }
  .product-card__image {
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    transition: transform var(--duration-slow) var(--ease-editorial);
  }
  .product-card:hover .product-card__image {
    transform: scale(1.03);
  }
  .product-card__body {
    padding-top: var(--space-2);
  }
  .product-card__body h3 {
    font-size: var(--text-lg);
  }
  .product-card__desc {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
    min-height: 2.6em;
  }
  .product-card__meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .product-card__price {
    font-family: var(--font-heading-en);
    color: var(--color-ink);
    font-size: var(--text-base);
  }
  .product-card__note {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .product-card__note--soldout {
    color: var(--color-accent-text);
  }
  .product-card--sold-out .product-card__image {
    filter: saturate(0.4);
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card__image {
      transition: none;
    }
  }
</style>
