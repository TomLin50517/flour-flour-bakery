---
// ProductCard.astro — 極簡編輯感:4:5 影像佔位(curtain reveal + slow drift)→ 名稱 → 英文名 → 價格・狀態
// 狀態六種,全語系皆用英文編輯體;Seasonal/Holiday Edition 用低彩度小型 tag,其餘維持純文字。
// 描述與確切數量留給商品詳細頁(之後可接每日少量製作/售完為止或訂單系統)。
import ImagePlaceholder from './ImagePlaceholder.astro';

export interface Props {
  item: {
    id: string;
    name: string;
    nameEn: string;
    price: number;
    status: 'available' | 'limited' | 'seasonal' | 'holiday' | 'weekend' | 'soldout';
    image?: string; // 正式攝影路徑;未提供則沿用佔位系統
  };
  // 首頁「今日出爐」以情緒與攝影帶場,不出現價格(emotion before information);
  // 售賣意圖留在商品頁,故該頁維持 showPrice=true。
  showPrice?: boolean;
}

const { item, showPrice = true } = Astro.props;
const statusLabels = {
  available: 'Available Today',
  limited: 'Limited Bake',
  seasonal: 'Seasonal',
  holiday: 'Holiday Edition',
  weekend: 'Weekend Only',
  soldout: 'Sold Out',
} as const;
const tagStatuses = new Set(['seasonal', 'holiday']);
---

<article class:list={['product-card', { 'product-card--sold-out': item.status === 'soldout' }]} data-product-id={item.id}>
  <div class="product-card__frame reveal-media">
    {item.image ? (
      <img src={item.image} alt={item.name} class="product-card__photo" width="800" height="1000" loading="lazy" />
    ) : (
      <ImagePlaceholder label="Product Photography" ratio="4:5" aspect="4 / 5" class="product-card__placeholder" />
    )}
  </div>
  <div class="product-card__body reveal-text">
    <h3>{item.name}</h3>
    {item.nameEn !== item.name && <p class="product-card__name-en">{item.nameEn}</p>}
    <p class:list={['product-card__meta', { 'product-card__meta--no-price': !showPrice }]}>
      {showPrice && <span class="product-card__price">NT$ {item.price}</span>}
      {tagStatuses.has(item.status) ? (
        <span class:list={['product-card__tag', `product-card__tag--${item.status}`]}>{statusLabels[item.status]}</span>
      ) : (
        <span class:list={['product-card__status', `product-card__status--${item.status}`]}>{statusLabels[item.status]}</span>
      )}
    </p>
  </div>
</article>

<style>
  .product-card__frame {
    overflow: hidden;
  }
  .product-card__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .product-card__body {
    padding-top: var(--space-2);
  }
  .product-card__body h3 {
    font-size: var(--text-lg);
  }
  .product-card__name-en {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-top: 4px;
  }
  .product-card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  /* 無價格時,狀態文字靠左對齊,維持與名稱同一條垂直節奏 */
  .product-card__meta--no-price {
    justify-content: flex-start;
  }
  .product-card__price {
    font-family: var(--font-heading-en);
    color: var(--color-ink);
    font-size: var(--text-base);
  }
  .product-card__status {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .product-card__status--limited,
  .product-card__status--weekend {
    color: var(--color-accent-text);
  }
  .product-card__tag {
    font-family: var(--font-body-en);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    background: var(--placeholder-bg);
    border: 1px solid var(--placeholder-border);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
  }
  .product-card--sold-out :global(.product-card__placeholder),
  .product-card--sold-out .product-card__photo {
    filter: saturate(0.4);
    opacity: 0.55;
  }
  .product-card--sold-out .product-card__status {
    color: var(--color-muted);
  }
</style>
