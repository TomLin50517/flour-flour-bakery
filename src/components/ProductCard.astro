---
// ProductCard.astro — 極簡編輯感:4:5 影像(curtain reveal + slow drift)→ 品名 → 一句說明標語 → 價格。
// 資料來自 products.json(見 src/data/products.ts);含酒精品項另加銅色「含酒精」飲食標籤。
import ImagePlaceholder from './ImagePlaceholder.astro';

export interface Props {
  item: {
    id: string;
    name: string;
    tagline: string;
    price: number;
    image?: string | null;
    containsAlcohol?: boolean;
  };
  // 首頁「特別推薦」以情緒與攝影帶場,不出現價格(emotion before information);商品頁維持 showPrice=true。
  showPrice?: boolean;
  // 「含酒精」標籤文字,隨語系傳入(products.alcoholLabel);未傳則退回英文。
  alcoholLabel?: string;
}

const { item, showPrice = true, alcoholLabel = 'Contains Alcohol' } = Astro.props;
const showMeta = showPrice || item.containsAlcohol;
---

<article class="product-card" data-product-id={item.id}>
  <div class="product-card__frame reveal-media">
    {item.image ? (
      <img src={item.image} alt={item.name} class="product-card__photo" width="800" height="1000" loading="lazy" />
    ) : (
      <ImagePlaceholder label="Product Photography" ratio="4:5" aspect="4 / 5" class="product-card__placeholder" />
    )}
  </div>
  <div class="product-card__body reveal-text">
    <h3>{item.name}</h3>
    {item.tagline && <p class="product-card__tagline">{item.tagline}</p>}
    {showMeta && (
      <p class="product-card__meta">
        {showPrice && <span class="product-card__price">NT$ {item.price}</span>}
        {item.containsAlcohol && (
          <span class="product-card__tag product-card__tag--alcohol">{alcoholLabel}</span>
        )}
      </p>
    )}
  </div>
</article>

<style>
  .product-card__frame {
    overflow: hidden;
  }
  .product-card__photo {
    width: 100%;
    height: auto; /* 讓 aspect-ratio 主導高度,否則 <img height> 屬性會蓋掉比例 */
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: opacity var(--duration-micro) var(--ease-editorial);
  }
  /* 極克制的 hover:影像微微沉一階,策展感的「呼吸」,不用 scale */
  .product-card:hover .product-card__photo {
    opacity: 0.9;
  }
  @media (prefers-reduced-motion: reduce) {
    .product-card__photo {
      transition: none;
    }
  }
  .product-card__body {
    padding-top: var(--space-2);
  }
  .product-card__body h3 {
    font-size: var(--text-lg);
  }
  /* 說明標語:安靜的編輯感副標,承接品名下方的情緒 */
  .product-card__tagline {
    font-family: var(--font-body-locale);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin-top: 6px;
    max-width: 34ch;
  }
  .product-card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .product-card__price {
    font-family: var(--font-ui); /* 價格走無襯線數字,不用 serif,且不搶過品名 */
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    color: var(--color-ink-soft);
    font-size: var(--text-base);
  }
  /* 含酒精:飲食提示,以克制的銅色點出,字型走全語系備援鏈(標籤文字會在地化) */
  .product-card__tag {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    padding: 3px 10px;
  }
  .product-card__tag--alcohol {
    color: var(--color-accent-text);
    background: color-mix(in srgb, var(--color-accent), transparent 92%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 55%);
    margin-left: auto;
  }
</style>
