---
// ProductCard.astro — 極簡編輯感:4:5 影像(curtain reveal + slow drift)→ 名稱 → 英文名 → 價格・狀態
// 狀態僅三種(Available Today / Limited Bake / Sold Out,全語系皆用英文編輯體);描述與數量留給商品詳細頁
export interface Props {
  item: {
    id: string;
    name: string;
    nameEn: string;
    price: number;
    status: 'available' | 'limited' | 'soldout';
  };
}

const { item } = Astro.props;
const statusLabels = {
  available: 'Available Today',
  limited: 'Limited Bake',
  soldout: 'Sold Out',
} as const;
---

<article class:list={['product-card', { 'product-card--sold-out': item.status === 'soldout' }]} data-product-id={item.id}>
  <div class="product-card__frame reveal-media">
    <div class="product-card__image" aria-hidden="true">4:5</div>
  </div>
  <div class="product-card__body reveal-text">
    <h3>{item.name}</h3>
    {item.nameEn !== item.name && <p class="product-card__name-en">{item.nameEn}</p>}
    <p class="product-card__meta">
      <span class="product-card__price">NT$ {item.price}</span>
      <span class:list={['product-card__status', `product-card__status--${item.status}`]}>{statusLabels[item.status]}</span>
    </p>
  </div>
</article>

<style>
  .product-card__frame {
    overflow: hidden;
  }
  .product-card__image {
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }
  .product-card__body {
    padding-top: var(--space-2);
  }
  .product-card__body h3 {
    font-size: var(--text-lg);
  }
  .product-card__name-en {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-top: 4px;
  }
  .product-card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .product-card__price {
    font-family: var(--font-heading-en);
    color: var(--color-ink);
    font-size: var(--text-base);
  }
  .product-card__status {
    font-family: var(--font-body-en);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .product-card__status--limited {
    color: var(--color-accent-text);
  }
  .product-card--sold-out .product-card__image {
    filter: saturate(0.4);
    opacity: 0.55;
  }
  .product-card--sold-out .product-card__status {
    color: var(--color-muted);
  }
</style>
