---
// Footer.astro — 深墨底、大量留白:左側大字 Baked by the River.,右側 Visit / Follow / Information
export interface Props {
  lang: 'zh-hant' | 'en' | 'ja' | 'ko';
  footer: {
    visitHeading: string;
    followHeading: string;
    infoHeading: string;
    copyright: string;
    privacyLink: string;
  };
  nav: { story: string; products: string; service: string; contact: string };
  contact: { phoneValue: string; emailValue: string; addressValue: string; hoursValue: string; instagram: string; line: string };
}

const { lang, footer, nav, contact } = Astro.props;
const localePrefix = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' } as const;
const p = localePrefix[lang];
const igHref = `https://www.instagram.com/${contact.instagram.replace('@', '')}/`;
const lineHref = `https://line.me/R/ti/p/${encodeURIComponent(contact.line)}`;
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__statement">
      <p>Baked by<br />the River.</p>
    </div>

    <div class="site-footer__columns">
      <div class="site-footer__col">
        <h3>{footer.visitHeading}</h3>
        <p>{contact.addressValue}</p>
        <p>{contact.hoursValue}</p>
        <p>{contact.phoneValue}</p>
      </div>
      <div class="site-footer__col">
        <h3>{footer.followHeading}</h3>
        <a href={igHref} target="_blank" rel="noopener">Instagram</a>
        <a href={lineHref} target="_blank" rel="noopener">LINE</a>
      </div>
      <div class="site-footer__col">
        <h3>{footer.infoHeading}</h3>
        <a href={`${p}/service`}>{nav.service}</a>
        <a href={`${p}/contact`}>{nav.contact}</a>
        <a href={`${p}/privacy`}>{footer.privacyLink}</a>
      </div>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <span>{footer.copyright}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--deep-ink);
    color: var(--flour-white);
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    padding-block: var(--space-8) var(--space-7);
    align-items: start;
  }
  .site-footer__statement p {
    font-family: var(--font-heading-en);
    font-style: italic;
    font-size: var(--text-4xl);
    line-height: 1.15;
    letter-spacing: 0.01em;
  }
  .site-footer__columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .site-footer__col h3 {
    font-family: var(--font-ui);
    font-size: var(--text-eyebrow);
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--river-grey);
    margin-bottom: var(--space-3);
  }
  .site-footer__col p,
  .site-footer__col a {
    display: block;
    font-size: var(--text-sm);
    color: var(--flour-white);
    text-decoration: none;
    margin-top: var(--space-1);
  }
  .site-footer__col a {
    width: fit-content;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-base) var(--ease-editorial);
  }
  .site-footer__col a:hover {
    border-color: var(--sunset-copper);
  }
  .site-footer__bottom {
    border-top: 1px solid rgba(243, 239, 232, 0.12);
    padding-block: var(--space-3);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.08em;
    color: var(--river-grey);
  }

  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      padding-block: var(--space-7) var(--space-6);
    }
    .site-footer__columns {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
