---
// MapEmbed.astro(spec §5.5):click-to-load 門面,避免第三方資源拖累效能與預先載入 cookie
export interface Props {
  placeholderText: string;
  loadCta: string;
  address: string;
  autoload?: boolean; // true 時直接內嵌地圖(不需點擊);預設維持 click-to-load
}

const { placeholderText, loadCta, address, autoload = false } = Astro.props;
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(address)}&output=embed`;
---

<div class="map-embed" data-map-src={mapSrc}>
  {autoload ? (
    <iframe src={mapSrc} loading="lazy" title="Google Maps" class="map-embed__iframe"></iframe>
  ) : (
    <div class="map-embed__placeholder">
      <p>{placeholderText}</p>
      <button type="button" class="btn map-embed__load-btn">{loadCta}</button>
    </div>
  )}
</div>

<style>
  .map-embed {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-line);
  }
  .map-embed__iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .map-embed__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: var(--color-line);
    color: var(--color-ink-soft);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.map-embed').forEach((container) => {
    const btn = container.querySelector('.map-embed__load-btn');
    btn?.addEventListener('click', () => {
      const src = container.dataset.mapSrc;
      if (!src) return;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.loading = 'lazy';
      iframe.title = 'Google Maps';
      iframe.style.width = '100%';
      iframe.style.height = '100%';
      iframe.style.border = '0';
      container.innerHTML = '';
      container.appendChild(iframe);
    });
  });
</script>
