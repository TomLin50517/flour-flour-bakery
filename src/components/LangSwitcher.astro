---
// LangSwitcher.astro — 語言切換下拉:收合時直接顯示目前語言的完整原生名稱(如「繁體中文」)+ ▼,
// 而非圖示/縮寫/國旗,讓第一次使用的人一眼就能認出這是語言切換;點開後列出四語系完整名稱。
export interface Props {
  lang: 'zh-hant' | 'en' | 'ja' | 'ko';
  path: string; // 不含語系前綴,如 '/', '/story'
  labels: Record<string, string>;
}

const { lang, path, labels } = Astro.props;

const localePrefix = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' } as const;
const locales = ['zh-hant', 'en', 'ja', 'ko'] as const;
---

<details class="lang-select">
  <summary aria-label={labels.label}>
    <span>{labels[lang]}</span>
    <span class="lang-select__caret" aria-hidden="true">▼</span>
  </summary>
  <ul>
    {locales.map((l) => (
      <li>
        <a href={`${localePrefix[l]}${path}`} aria-current={l === lang ? 'true' : undefined}>
          {labels[l]}
        </a>
      </li>
    ))}
  </ul>
</details>

<style>
  .lang-select {
    position: relative;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }
  .lang-select summary {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    cursor: pointer;
    letter-spacing: 0.04em;
    color: var(--lang-switcher-color, var(--color-ink));
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--duration-base) var(--ease-editorial);
  }
  .lang-select summary::-webkit-details-marker {
    display: none;
  }
  .lang-select summary:hover {
    color: var(--sunset-copper);
  }
  .lang-select__caret {
    font-size: 8px;
    opacity: 0.7;
    transition: transform var(--duration-base) var(--ease-editorial);
  }
  .lang-select[open] .lang-select__caret {
    transform: rotate(180deg);
  }
  .lang-select[open] ul {
    position: absolute;
    top: calc(100% + 14px);
    right: 0;
    margin: 0;
    padding: var(--space-2) 0;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    min-width: 140px;
    z-index: 50;
  }
  .lang-select a {
    display: block;
    padding: 8px var(--space-3);
    text-decoration: none;
    color: var(--color-ink-soft);
    white-space: nowrap;
  }
  .lang-select a:hover {
    color: var(--color-accent-text);
  }
  .lang-select a[aria-current='true'] {
    color: var(--color-ink);
    font-weight: 500;
  }
</style>

<script>
  // 點擊選單外自動收合
  document.querySelectorAll<HTMLDetailsElement>('.lang-select').forEach((menu) => {
    document.addEventListener('click', (e) => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    });
  });
</script>
