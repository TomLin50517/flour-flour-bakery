---
// LangSwitcher.astro — 一排語系徽章(圓形短碼,非國旗——語言≠國籍),四語一次呈現、無需點開即可辨識;
// 切換後停留在同頁對應語系。size="sm" 給 mobile 選單用,略縮小間距。
export interface Props {
  lang: 'zh-hant' | 'en' | 'ja' | 'ko';
  path: string; // 不含語系前綴,如 '/', '/story'
  labels: Record<string, string>;
  size?: 'md' | 'sm';
}

const { lang, path, labels, size = 'md' } = Astro.props;

const localePrefix = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' } as const;
const locales = ['zh-hant', 'en', 'ja', 'ko'] as const;
const badge = { 'zh-hant': '繁', en: 'EN', ja: '日', ko: '한' } as const;
---

<nav class:list={['lang-badges', `lang-badges--${size}`]} aria-label={labels.label}>
  {locales.map((l) => (
    <a
      href={`${localePrefix[l]}${path}`}
      aria-current={l === lang ? 'true' : undefined}
      aria-label={labels[l]}
      title={labels[l]}
      data-lang-link={l}
    >
      {badge[l]}
    </a>
  ))}
</nav>

<style>
  .lang-badges {
    display: flex;
    gap: 6px;
  }
  .lang-badges a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--lang-switcher-color, var(--color-ink-soft));
    color: var(--lang-switcher-color, var(--color-ink-soft));
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background var(--duration-base) var(--ease-editorial),
      color var(--duration-base) var(--ease-editorial),
      border-color var(--duration-base) var(--ease-editorial);
  }
  .lang-badges--sm a {
    width: 26px;
    height: 26px;
    font-size: 10px;
  }
  .lang-badges a:hover {
    border-color: var(--sunset-copper);
    color: var(--sunset-copper);
  }
  .lang-badges a[aria-current='true'] {
    background: var(--lang-switcher-active-bg, var(--color-ink));
    border-color: var(--lang-switcher-active-bg, var(--color-ink));
    color: var(--lang-switcher-active-color, var(--flour-white));
  }
</style>
