---
// Header.astro — 三欄式:左 Story/Collection/Visit、中央 Logo、右 語言下拉/Reserve
// 首頁初始透明疊於 hero,捲動後轉為暖白;內頁固定暖白。導覽採英文編輯體(與 eyebrow 一致),
// 客服/聯絡/隱私等功能性連結移至 Footer。Journal 需待日誌內容建立後再加入。
import LangSwitcher from './LangSwitcher.astro';

export interface Props {
  lang: 'zh-hant' | 'en' | 'ja' | 'ko';
  path: string;
  langLabels: Record<string, string>;
  transparent?: boolean;
  reservePhone: string;
}

const { lang, path, langLabels, transparent = false, reservePhone } = Astro.props;
const localePrefix = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' } as const;
const p = localePrefix[lang];
const home = p || '/';
const reserveHref = `tel:${reservePhone.replace(/-/g, '')}`;

const navLeft = [
  { label: 'Story', href: `${p}/story` },
  { label: 'Collection', href: `${p}/products` },
  { label: 'Visit', href: `${p}/contact` },
];
---

<header class:list={['site-header', { 'site-header--transparent': transparent }]}>
  <div class="container site-header__inner">
    <nav class="site-header__nav site-header__nav--left" aria-label="primary">
      {navLeft.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a href={home} class="site-header__brand" aria-label="FlourFlour BAKERY">
      <img src="/images/logo-horizontal-ink.png" alt="FlourFlour BAKERY" class="site-header__logo" />
    </a>

    <div class="site-header__right">
      <LangSwitcher lang={lang} path={path} labels={langLabels} variant="dropdown" />
      <a class="site-header__reserve" href={reserveHref}>Reserve</a>
    </div>

    <button
      type="button"
      class="site-header__toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav class="mobile-menu__nav" aria-label="mobile primary">
      {navLeft.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={reserveHref}>Reserve</a>
    </nav>
    <div class="mobile-menu__lang">
      <LangSwitcher lang={lang} path={path} labels={langLabels} variant="inline" />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-line);
    background: var(--color-bg);
    position: relative;
    z-index: 30;
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-2);
  }
  .site-header__brand {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__logo {
    height: 34px;
    width: auto;
    transition: filter var(--duration-base) var(--ease-editorial);
  }
  .site-header__nav {
    display: flex;
    gap: var(--space-4);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .site-header__nav a {
    text-decoration: none;
    color: var(--color-ink);
    transition: color var(--duration-base) var(--ease-editorial);
  }
  .site-header__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-4);
  }
  .site-header__reserve {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-ink);
    padding-bottom: 2px;
    border-bottom: 1px solid currentColor;
    transition: color var(--duration-base) var(--ease-editorial);
  }
  .site-header__reserve:hover {
    color: var(--color-accent-text);
  }

  /* transparent state over the hero:白色 logo 以 filter 產生,捲動後還原墨色 */
  .site-header--transparent {
    position: absolute;
    inset-inline: 0;
    top: 0;
    background: transparent;
    border-bottom-color: transparent;
    transition: background var(--duration-base) var(--ease-editorial),
      border-color var(--duration-base) var(--ease-editorial);
  }
  .site-header--transparent .site-header__logo {
    filter: brightness(0) invert(1);
  }
  .site-header--transparent .site-header__nav a,
  .site-header--transparent .site-header__reserve {
    color: var(--flour-white);
  }
  .site-header--transparent .site-header__right {
    --lang-switcher-color: var(--flour-white);
  }
  .site-header--transparent .site-header__toggle span {
    background-color: var(--flour-white);
  }
  .site-header--transparent.is-scrolled {
    position: fixed;
    background: var(--color-bg);
    border-bottom-color: var(--color-line);
  }
  .site-header--transparent.is-scrolled .site-header__logo {
    filter: none;
  }
  .site-header--transparent.is-scrolled .site-header__nav a,
  .site-header--transparent.is-scrolled .site-header__reserve {
    color: var(--color-ink);
  }
  .site-header--transparent.is-scrolled .site-header__right {
    --lang-switcher-color: var(--color-ink);
  }
  .site-header--transparent.is-scrolled .site-header__toggle span {
    background-color: var(--color-ink);
  }

  .site-header__toggle {
    display: none;
    grid-column: 3;
    justify-self: end;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .site-header__toggle span {
    display: block;
    height: 1px;
    background: var(--color-ink);
    transition: background var(--duration-base) var(--ease-editorial);
  }
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 63px;
    background: var(--color-bg);
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-4) var(--space-3);
    z-index: 40;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-editorial);
  }
  .mobile-menu:not([hidden]) {
    display: flex;
    opacity: 1;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-family: var(--font-heading-locale);
    font-size: var(--text-xl);
  }
  .mobile-menu__nav a {
    text-decoration: none;
    color: var(--color-ink);
  }

  @media (max-width: 900px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }
    .site-header__brand {
      grid-column: 1;
      justify-content: flex-start;
    }
    .site-header__nav--left,
    .site-header__right {
      display: none;
    }
    .site-header__toggle {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .site-header--transparent,
    .site-header__logo {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-header__toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (menu) menu.hidden = expanded;
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      if (menu) menu.hidden = true;
    });
  });

  const header = document.querySelector<HTMLElement>('.site-header--transparent');
  if (header) {
    const update = () => {
      header.classList.toggle('is-scrolled', window.scrollY > window.innerHeight * 0.8);
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
