---
// Base.astro — 全站共用外殼(spec §6):載入設計 token、字型、meta、hreflang、Header/Footer
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getDict, localePrefix, locales, type Lang } from '../i18n';
import zhHant from '../i18n/zh-hant.json';

export interface Props {
  lang: Lang;
  title: string;
  description: string;
  path: string; // 不含語系前綴的頁面路徑,如 '/', '/story'
  transparentHeader?: boolean; // 首頁全螢幕 hero 用透明 header
}

const { lang, title, description, path, transparentHeader = false } = Astro.props;

const htmlLang = { 'zh-hant': 'zh-Hant', en: 'en', ja: 'ja', ko: 'ko' } as const;
const t = getDict(lang);

const siteUrl = 'https://flourflour.com.tw';
const canonicalPath = `${localePrefix[lang]}${path}`;
const ogLocale = { 'zh-hant': 'zh_TW', en: 'en_US', ja: 'ja_JP', ko: 'ko_KR' } as const;

// JSON-LD Bakery(LocalBusiness)— spec §6;地址採繁中原文以利地圖/在地搜尋辨識,geo 為淡水老街概略座標(待實際地址確認後更新)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Bakery',
  name: 'FlourFlour BAKERY',
  description,
  url: `${siteUrl}${canonicalPath}`,
  telephone: zhHant.contact.phoneValue,
  email: zhHant.contact.emailValue,
  address: {
    '@type': 'PostalAddress',
    streetAddress: zhHant.contact.addressValue,
    addressLocality: '淡水區',
    addressRegion: '新北市',
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 25.17,
    longitude: 121.4393,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '11:00',
    closes: '19:00',
  },
  sameAs: [`https://www.instagram.com/${zhHant.contact.instagram.replace('@', '')}/`],
};
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 首次造訪依瀏覽器語言自動導向對應語系頁面(不在支援語系內則預設繁中);
         只在使用者尚未有語系偏好紀錄時執行一次,之後(含手動切換語言後)不再自動判斷/導向,
         避免每次載入都打斷使用者已做的語言選擇。放在 head 最前面,盡量在繪製前完成導向判斷。 -->
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'ff-lang-pref';
        try {
          if (localStorage.getItem(STORAGE_KEY)) return;
        } catch (e) {
          return;
        }

        var prefixes = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' };

        function detect() {
          var langs =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || ''];
          for (var i = 0; i < langs.length; i++) {
            var l = (langs[i] || '').toLowerCase();
            if (l.indexOf('zh') === 0) return 'zh-hant';
            if (l.indexOf('en') === 0) return 'en';
            if (l.indexOf('ja') === 0) return 'ja';
            if (l.indexOf('ko') === 0) return 'ko';
          }
          return 'zh-hant';
        }

        var path = window.location.pathname;
        var current = 'zh-hant';
        if (path === '/en' || path.indexOf('/en/') === 0) current = 'en';
        else if (path === '/ja' || path.indexOf('/ja/') === 0) current = 'ja';
        else if (path === '/ko' || path.indexOf('/ko/') === 0) current = 'ko';

        var target = detect();

        try {
          localStorage.setItem(STORAGE_KEY, target);
        } catch (e) {}

        if (target !== current) {
          var currentPrefix = prefixes[current];
          var rest = currentPrefix ? path.slice(currentPrefix.length) : path;
          if (!rest) rest = '/';
          window.location.replace(prefixes[target] + rest + window.location.search + window.location.hash);
        }
      })();
    </script>
    <!-- 漸進增強:先同步標記 JS 可用,.reveal-text/.reveal-media 的進場隱藏樣式只在此 class 存在時生效
         (見 global.css)。JS 關閉或載入失敗時,內容維持一般可見,不依賴後續進場動畫。 -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}${canonicalPath}`} />
    {locales.map((l) => (
      <link rel="alternate" hreflang={htmlLang[l]} href={`${siteUrl}${localePrefix[l]}${path}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${path}`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FlourFlour BAKERY" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${canonicalPath}`} />
    <meta property="og:locale" content={ogLocale[lang]} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- TODO 字型:v1 先用 Google Fonts CDN 連結(下方),之後改自架子集 woff2(public/fonts/,spec §3.2/§6） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500&family=Noto+Serif+TC:wght@400;500&family=Noto+Sans+TC:wght@300;400;500&family=Shippori+Mincho:wght@400;500&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+KR:wght@400;500&family=Noto+Sans+KR:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- TODO: 流量分析插入點(v1 不安裝,spec §6) -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    {t.announcement.enabled && (
      <div class="announcement-bar">
        <p class="container">{t.announcement.text}</p>
      </div>
    )}
    <Header
      lang={lang}
      path={path}
      langLabels={t.langSwitcher}
      transparent={transparentHeader}
      reserveEmail={t.contact.emailValue}
    />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} footer={t.footer} nav={t.nav} contact={t.contact} />

    <script>
      const revealEls = document.querySelectorAll('.reveal-text, .reveal-media');

      // 保險機制:若元素在進入視窗後 2.5 秒內仍未被 observer 標記可見(無論何種原因),
      // 強制加上 is-visible,確保內容不會永久卡在隱藏狀態。
      const revealNow = (el: Element) => el.classList.add('is-visible');
      const scheduleFallback = (el: Element) => setTimeout(() => revealNow(el), 2500);

      if (!('IntersectionObserver' in window)) {
        revealEls.forEach(revealNow);
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                revealNow(entry.target);
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        revealEls.forEach((el) => {
          observer.observe(el);
          scheduleFallback(el);
        });
      }
    </script>
  </body>
</html>

<style>
  .announcement-bar {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  .announcement-bar p {
    padding-block: 10px;
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    text-align: center;
  }
</style>
