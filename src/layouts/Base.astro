---
// Base.astro — 全站共用外殼(spec §6):載入設計 token、字型、meta、hreflang、Header/Footer
import '../styles/global.css';

// 自架字型(取代 Google Fonts CDN,GDPR)。
// 拉丁字(Cormorant+Inter)檔案小,沿用 @fontsource,隨頁面打包。
import '../styles/fonts-common.scss';
// CJK 改用 content-based 子集:只含網站真正用到的字,每語系 4 個檔(繁中約 737KB,原本要抓 1.75MB/47 檔)。
// 由 scripts/subset-fonts.mjs 於建置前產生 public/fonts/ 與此 manifest(檔名含內容雜湊)。
import fontManifest from '../../public/fonts/manifest.json';

// 首屏最顯眼文字的字型 preload:讓「第一次訪客」在首次繪製時就有品牌字,不再先系統字→跳字。
// ?url 取得建置後的雜湊路徑。Inter(全站 header 導覽,每頁都在首屏)+ Cormorant 斜體(首頁 Hero 大標)。
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interLatin500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import cormorantItalic500 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-italic.woff2?url';
// 英文頁的 --font-heading-locale 就是 Cormorant 正體(等同中文頁的 Noto Serif TC),
// 未預載會先以系統襯線字繪製、載入後才縮成 Cormorant(字面差很多)→ 明顯的大小跳動。
import cormorantNormal500 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getDict, getBusinessInfo, localePrefix, locales, type Lang } from '../i18n';
import announcement from '../data/announcement.json';

export interface Props {
  lang: Lang;
  title: string;
  description: string;
  path: string; // 不含語系前綴的頁面路徑,如 '/', '/story'
  transparentHeader?: boolean; // 首頁全螢幕 hero 用透明 header
}

const { lang, title, description, path, transparentHeader = false } = Astro.props;

const htmlLang = { 'zh-hant': 'zh-Hant', en: 'en', ja: 'ja', ko: 'ko' } as const;
const t = getDict(lang);
const b = getBusinessInfo(lang);
const bizZh = getBusinessInfo('zh-hant'); // JSON-LD 採繁中原文為單一標準值

const siteUrl = 'https://flourflour.com.tw';
const canonicalPath = `${localePrefix[lang]}${path}`;
const ogLocale = { 'zh-hant': 'zh_TW', en: 'en_US', ja: 'ja_JP', ko: 'ko_KR' } as const;

// 本頁需要的 CJK 字型(英文頁僅需共用拉丁字,故為 null)。各語系只載自己的子集;
// 跨語系的罕見字會退回系統中文字型(不會是豆腐字)。
const manifestKey = { 'zh-hant': 'zh', ja: 'ja', ko: 'ko', en: null } as const;
const cjkFonts = manifestKey[lang]
  ? (fontManifest as Record<string, { css: string; preload: string[] }>)[manifestKey[lang]!]
  : null;

// JSON-LD Bakery(LocalBusiness)— spec §6;地址採繁中原文以利地圖/在地搜尋辨識,geo 為淡水老街概略座標(待實際地址確認後更新)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Bakery',
  name: 'FlourFlour BAKERY',
  description,
  url: `${siteUrl}${canonicalPath}`,
  telephone: bizZh.phone,
  email: bizZh.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: bizZh.address,
    addressLocality: '淡水區',
    addressRegion: '新北市',
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 25.1723491,
    longitude: 121.4362253,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: bizZh.hoursSpec.opens, // 與 business-info.json 的 hours 顯示字串同源,改一處即同步
    closes: bizZh.hoursSpec.closes,
  },
  sameAs: [`https://www.instagram.com/${bizZh.instagram.replace('@', '')}/`],
};
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 首次造訪依瀏覽器語言自動導向對應語系頁面(不在支援語系內則預設繁中);
         只在使用者尚未有語系偏好紀錄時執行一次,之後(含手動切換語言後)不再自動判斷/導向,
         避免每次載入都打斷使用者已做的語言選擇。放在 head 最前面,盡量在繪製前完成導向判斷。 -->
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'ff-lang-pref';
        try {
          if (localStorage.getItem(STORAGE_KEY)) return;
        } catch (e) {
          return;
        }

        var prefixes = { 'zh-hant': '', en: '/en', ja: '/ja', ko: '/ko' };

        function detect() {
          var langs =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || ''];
          for (var i = 0; i < langs.length; i++) {
            var l = (langs[i] || '').toLowerCase();
            if (l.indexOf('zh') === 0) return 'zh-hant';
            if (l.indexOf('en') === 0) return 'en';
            if (l.indexOf('ja') === 0) return 'ja';
            if (l.indexOf('ko') === 0) return 'ko';
          }
          return 'zh-hant';
        }

        var path = window.location.pathname;
        var current = 'zh-hant';
        if (path === '/en' || path.indexOf('/en/') === 0) current = 'en';
        else if (path === '/ja' || path.indexOf('/ja/') === 0) current = 'ja';
        else if (path === '/ko' || path.indexOf('/ko/') === 0) current = 'ko';

        var target = detect();

        try {
          localStorage.setItem(STORAGE_KEY, target);
        } catch (e) {}

        if (target !== current) {
          var currentPrefix = prefixes[current];
          var rest = currentPrefix ? path.slice(currentPrefix.length) : path;
          if (!rest) rest = '/';
          window.location.replace(prefixes[target] + rest + window.location.search + window.location.hash);
        }
      })();
    </script>
    <!-- 漸進增強:先同步標記 JS 可用,.reveal-text/.reveal-media 的進場隱藏樣式只在此 class 存在時生效
         (見 global.css)。JS 關閉或載入失敗時,內容維持一般可見,不依賴後續進場動畫。 -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}${canonicalPath}`} />
    {locales.map((l) => (
      <link rel="alternate" hreflang={htmlLang[l]} href={`${siteUrl}${localePrefix[l]}${path}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${path}`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FlourFlour BAKERY" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${canonicalPath}`} />
    <meta property="og:locale" content={ogLocale[lang]} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* 本語系的 CJK 子集字型:CSS 僅 4 條 @font-face(約 1KB),瀏覽器幾乎立刻就知道要抓哪些檔;
        再 preload 首屏關鍵的標題/內文兩個字重,讓字型在首次繪製前到位 → 不再「先系統字再換字」。 */}
    {cjkFonts && (
      <>
        <link rel="stylesheet" href={cjkFonts.css} />
        {cjkFonts.preload.map((href) => (
          <link rel="preload" as="font" type="font/woff2" href={href} crossorigin />
        ))}
      </>
    )}

    {/* 首屏字型 preload:Inter(每頁 header 導覽)全站預載;Cormorant 斜體大標僅首頁 Hero 需要。
        crossorigin 為字型 preload 必要屬性(字型一律以 CORS 模式抓取,漏了會重複下載)。 */}
    <link rel="preload" as="font" type="font/woff2" href={interLatin400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatin500} crossorigin />

    {/* 英文頁的標題字型即 Cormorant 正體 → 與 CJK 頁預載 CJK 標題字型同理,必須預載 */}
    {lang === 'en' && (
      <link rel="preload" as="font" type="font/woff2" href={cormorantNormal500} crossorigin />
    )}

    {/* 首頁 Hero 為 LCP 影像:預先載入以縮短最大內容繪製時間(僅首頁載入) */}
    {path === '/' && (
      <>
        <link rel="preload" as="image" href="/images/hero-tamsui-bridge.jpg" fetchpriority="high" />
        <link rel="preload" as="font" type="font/woff2" href={cormorantItalic500} crossorigin />
      </>
    )}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- 字型已自架(見上方 frontmatter 的 @fontsource import),不再連 Google Fonts CDN。 -->

    <!-- TODO: 流量分析插入點(v1 不安裝,spec §6) -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    {announcement.enabled && (
      <div class="announcement-bar">
        <p class="container">{(announcement as Record<string, string>)[lang]}</p>
      </div>
    )}
    <Header
      lang={lang}
      path={path}
      langLabels={t.langSwitcher}
      transparent={transparentHeader}
      reserveEmail={b.email}
    />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} footer={t.footer} nav={t.nav} />
    <CookieConsent lang={lang} consent={t.cookieConsent} />

    <script>
      const revealEls = document.querySelectorAll('.reveal-text, .reveal-media');

      // 只「武裝」(隱藏+等待進場)「完全在首屏以下」的元素;首屏(初次已可見/半露出)的內容
      // 維持直接顯示、不依賴 JS → 避免 Chrome「空白一下再跳出」的頓感。門檻取整個視窗高度,
      // 確保被武裝元素的初始隱藏動畫一定發生在畫面外(使用者看不到收合)。
      const armThreshold = window.innerHeight;
      const belowFold = (el: Element) => el.getBoundingClientRect().top >= armThreshold;

      const revealNow = (el: Element) => el.classList.add('is-visible');

      // 待武裝清單:僅首屏以下元素。首屏元素不加 .reveal-armed,CSS 就不會隱藏它們
      // → 首屏內容隨頁面即時顯示、不依賴 JS,消除 Chrome「空白一下再跳出」的頓感。
      const toArm = Array.from(revealEls).filter(belowFold);

      if (!('IntersectionObserver' in window)) {
        // 極舊瀏覽器無 observer:直接全部顯示,確保內容不會卡住。
        toArm.forEach(revealNow);
      } else {
        // 下方元素「只在真正捲進畫面時」才浮現。不再用逾時保險提前在畫面外揭示,
        // 否則使用者慢慢往下捲時,區塊早已在畫面外被顯示完 → 進場效果會整個消失。
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                revealNow(entry.target);
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        toArm.forEach((el) => {
          el.classList.add('reveal-armed');
          observer.observe(el);
        });

        // 安全網:捲到接近頁面最底時,補顯示任何仍未現身的 armed 元素。
        // 這能救回「剛好落在頁面最底 10%、因 observer rootMargin 而永遠沒被觸發」的區塊,
        // 又不會提前在畫面外揭示(只在真的捲到底、元素已在畫面內時才補),故不影響正常進場效果。
        const revealRemaining = () => {
          if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4) {
            toArm.forEach((el) => {
              if (!el.classList.contains('is-visible')) revealNow(el);
            });
            window.removeEventListener('scroll', revealRemaining);
          }
        };
        window.addEventListener('scroll', revealRemaining, { passive: true });
      }
    </script>
  </body>
</html>

<style>
  .announcement-bar {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  .announcement-bar p {
    padding-block: 10px;
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    text-align: center;
  }
</style>
