---
// 404 頁(spec §5.6):靜態主機僅一份 404.html,無法按語系預產生;
// 預設顯示繁中,JS 依 location.pathname 前綴切換為對應語系文案(四語文案內嵌於同一頁)
import '../styles/global.css';
// 404 頁不走 Base,且以 JS 切換顯示四語系,故一次載入共用拉丁 + 全部 CJK 字型。
import '../styles/fonts-common.scss';
import '../styles/fonts-zh.scss';
import '../styles/fonts-ja.scss';
import '../styles/fonts-ko.scss';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getDict, getBusinessInfo, localePrefix, locales, type Lang } from '../i18n';

const htmlLang = { 'zh-hant': 'zh-Hant', en: 'en', ja: 'ja', ko: 'ko' } as const;
const defaultDict = getDict('zh-hant');
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{defaultDict.pageMeta.notFound.title}</title>
    <meta name="description" content={defaultDict.pageMeta.notFound.description} />
    <meta name="robots" content="noindex" />
    <script is:inline>
      // 於繪製前依網址前綴判定語系,設定 <html data-lang>(供 CSS 只顯示對應區塊,避免其他語系閃現繁中)與 lang。
      (function () {
        var p = location.pathname;
        var lang = 'zh-hant';
        if (p === '/en' || p.indexOf('/en/') === 0) lang = 'en';
        else if (p === '/ja' || p.indexOf('/ja/') === 0) lang = 'ja';
        else if (p === '/ko' || p.indexOf('/ko/') === 0) lang = 'ko';
        var htmlLang = { 'zh-hant': 'zh-Hant', en: 'en', ja: 'ja', ko: 'ko' }[lang];
        var de = document.documentElement;
        de.setAttribute('data-lang', lang);
        de.setAttribute('lang', htmlLang);
      })();
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- 字型已自架(見 frontmatter 的 fonts.css import),不再連 Google Fonts CDN。 -->
  </head>
  <body>
    {locales.map((lang: Lang) => {
      const t = getDict(lang);
      const b = getBusinessInfo(lang);
      const p = localePrefix[lang];
      return (
        <div
          class="notfound-locale"
          data-lang={lang}
          data-html-lang={htmlLang[lang]}
          data-title={t.pageMeta.notFound.title}
          data-description={t.pageMeta.notFound.description}
          hidden={lang !== 'zh-hant'}
        >
          <Header lang={lang} path="/404" langLabels={t.langSwitcher} reserveEmail={b.email} />
          <main class="notfound">
            <div class="container notfound__inner">
              <img src="/images/logo-flower-ink.png" alt="FlourFlour BAKERY" class="notfound__logo" />
              <p class="notfound__message">{t.notFound.message}</p>
              <div class="notfound__actions">
                <a class="btn btn--primary" href={p || '/'}>{t.notFound.homeCta}</a>
                <a class="notfound__link" href={`${p}/products`}>{t.notFound.productsCta} →</a>
              </div>
            </div>
          </main>
          <Footer lang={lang} footer={t.footer} nav={t.nav} />
        </div>
      );
    })}

    <script is:inline>
      // 語系已由 <head> 的 inline script 寫入 <html data-lang>;此處據此同步顯示區塊與 head 標題/描述。
      (function () {
        var de = document.documentElement;
        var lang = de.getAttribute('data-lang') || 'zh-hant';
        var meta = document.querySelector('meta[name="description"]');
        document.querySelectorAll('.notfound-locale').forEach(function (el) {
          var isMatch = el.getAttribute('data-lang') === lang;
          el.hidden = !isMatch;
          if (isMatch) {
            de.setAttribute('lang', el.getAttribute('data-html-lang') || 'zh-Hant');
            if (el.dataset.title) document.title = el.dataset.title;
            if (meta && el.dataset.description) meta.setAttribute('content', el.dataset.description);
          }
        });
      })();
    </script>
  </body>
</html>

<style>
  /* 首次繪製即依 <html data-lang> 顯示對應語系;無 JS 時回退顯示繁中,避免其他語系閃現繁中內容。 */
  .notfound-locale {
    display: none;
  }
  .notfound-locale[data-lang='zh-hant'] {
    display: block;
  }
  html[data-lang] .notfound-locale {
    display: none;
  }
  html[data-lang='zh-hant'] .notfound-locale[data-lang='zh-hant'],
  html[data-lang='en'] .notfound-locale[data-lang='en'],
  html[data-lang='ja'] .notfound-locale[data-lang='ja'],
  html[data-lang='ko'] .notfound-locale[data-lang='ko'] {
    display: block;
  }

  .notfound {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }
  .notfound__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }
  .notfound__logo {
    height: 64px;
    width: auto;
  }
  .notfound__message {
    font-family: var(--font-heading-locale);
    font-size: var(--text-2xl);
  }
  .notfound__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .notfound__link {
    color: var(--color-accent-text);
    text-decoration: none;
  }
</style>
